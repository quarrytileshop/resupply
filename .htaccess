# =============================================
# .htaccess - Simplified for GoDaddy shared hosting
# Updated May 14, 2026
# =============================================

# Protect sensitive files
<FilesMatch "^(includes/config\.php|database-setup\.sql|\.env|.*\.md|debug\.log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Default index file
DirectoryIndex index.php