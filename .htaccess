# Resupply Rocket Professional .htaccess (Updated for Chrome compatibility)
RewriteEngine On
Options -Indexes

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Security headers - relaxed X-Frame-Options so password managers work
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"   # CHANGED FROM DENY
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Protect sensitive files
<FilesMatch "(config|db_config|phpinfo|database-setup)">
    Order Allow,Deny
    Deny from all
</FilesMatch>
